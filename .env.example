# IA_SERVICE_URL apunta al smartauditoria_engine
IA_SERVICE_URL=http://localhost:8001
IA_SERVICE_API_KEY=

# Flask
FLASK_ENV=development
SECRET_KEY=<GENERAR_CON_secrets.token_urlsafe_32>
PORT=5000

# Base de datos
DATABASE_URL=mysql+pymysql://root:root@localhost/sgsri_db
# Para testing local sin MySQL:
# DATABASE_URL=sqlite:///./sgsri_test.db

# CORS
CORS_ORIGINS=http://localhost:5173,http://localhost:3000

# Alembic
# Usar 'alembic upgrade head' para aplicar migraciones
